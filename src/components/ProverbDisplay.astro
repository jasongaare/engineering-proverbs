---
interface Props {
  quote: string;
  author: string;
  source?: string;
}

const { quote, author, source } = Astro.props;
---

<article class="proverb">
  <blockquote>
    <p class="quote">{quote}</p>
  </blockquote>
  <footer class="attribution">
    <span class="author">— {author}</span>
    {source && <cite class="source">, {source}</cite>}
  </footer>
</article>

<style>
  .proverb {
    max-width: 42rem;
    margin: 0 auto;
    padding: 2rem;
    text-align: center;
  }

  blockquote {
    margin: 0;
    padding: 0;
  }

  .quote {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    line-height: 1.5;
    font-style: italic;
    color: #2c1810;
    margin: 0 0 1.5rem 0;
  }

  .quote::before {
    content: '"';
  }

  .quote::after {
    content: '"';
  }

  .attribution {
    font-size: 1.125rem;
    color: #5c4033;
  }

  .author {
    font-weight: 500;
  }

  .source {
    font-style: italic;
    opacity: 0.85;
  }
</style>
