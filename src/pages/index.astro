---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';

const allProverbs = await getCollection('proverbs');
const proverbsData = allProverbs.map(p => ({
  id: p.data.id,
  quote: p.data.quote,
  author: p.data.author,
  source: p.data.source,
}));
---

<Layout title="The Engineering Book of Proverbs">
	<main>
		<div class="book-page">
			<h1>The Engineering Book of Proverbs</h1>
			<div id="proverb-container" aria-live="polite">
			</div>
			<div class="button-row">
				<button class="refresh-btn" id="another-btn">Another proverb</button>
				<button class="share-btn" id="share-btn">Share</button>
			</div>
		</div>
	</main>
</Layout>

<script define:vars={{ proverbsData }}>
	const proverbs = proverbsData;
	const container = document.getElementById('proverb-container');
	const shareBtn = document.getElementById('share-btn');

	// Check for permalink parameter
	function getInitialIndex() {
		const params = new URLSearchParams(window.location.search);
		const q = params.get('q');
		if (q) {
			const id = parseInt(q, 10);
			const index = proverbs.findIndex(p => p.id === id);
			if (index !== -1) return index;
		}
		return Math.floor(Math.random() * proverbs.length);
	}

	let currentIndex = getInitialIndex();
	const recentHistory = [currentIndex];
	const historySize = Math.min(10, proverbs.length - 1);

	function updateUrl(proverb) {
		const url = new URL(window.location);
		url.searchParams.set('q', proverb.id);
		history.replaceState(null, '', url);
	}

	function renderProverb(proverb) {
		const sourceHtml = proverb.source
			? `<cite class="source">, ${proverb.source}</cite>`
			: '';

		container.innerHTML = `
			<article class="proverb">
				<blockquote>
					<p class="quote">${proverb.quote}</p>
				</blockquote>
				<footer class="attribution">
					<span class="author">— ${proverb.author}</span>
					${sourceHtml}
				</footer>
			</article>
		`;
	}

	// Show proverb on page load
	renderProverb(proverbs[currentIndex]);
	updateUrl(proverbs[currentIndex]);

	// Handle "Another proverb" button
	document.getElementById('another-btn').addEventListener('click', () => {
		let newIndex;
		do {
			newIndex = Math.floor(Math.random() * proverbs.length);
		} while (recentHistory.includes(newIndex) && proverbs.length > 1);
		currentIndex = newIndex;
		recentHistory.push(currentIndex);
		if (recentHistory.length > historySize) recentHistory.shift();

		container.style.opacity = '0';
		setTimeout(() => {
			renderProverb(proverbs[currentIndex]);
			updateUrl(proverbs[currentIndex]);
			container.style.opacity = '1';
		}, 200);
	});

	// Handle "Share" button
	shareBtn.addEventListener('click', () => {
		const url = window.location.href;
		navigator.clipboard.writeText(url).then(() => {
			shareBtn.textContent = 'Copied!';
			shareBtn.classList.add('copied');
			setTimeout(() => {
				shareBtn.textContent = 'Share';
				shareBtn.classList.remove('copied');
			}, 1500);
		});
	});

	// Keyboard shortcut: spacebar for next proverb
	document.addEventListener('keydown', (e) => {
		if (e.key === ' ' && e.target === document.body) {
			e.preventDefault();
			document.getElementById('another-btn').click();
		}
	});
</script>
