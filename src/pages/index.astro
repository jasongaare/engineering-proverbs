---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';
import ProverbDisplay from '../components/ProverbDisplay.astro';

const allProverbs = await getCollection('proverbs');
const proverbsData = allProverbs.map(p => ({
  quote: p.data.quote,
  author: p.data.author,
  source: p.data.source,
}));
---

<Layout title="The Engineering Book of Proverbs">
	<main>
		<div class="book-page">
			<h1>The Engineering Book of Proverbs</h1>
			<div id="proverb-container">
				<ProverbDisplay {...proverbsData[0]} />
			</div>
			<button class="refresh-btn" id="another-btn">Another proverb</button>
		</div>
	</main>
</Layout>

<script define:vars={{ proverbsData }}>
	const proverbs = proverbsData;
	let currentIndex = Math.floor(Math.random() * proverbs.length);

	function renderProverb(proverb) {
		const container = document.getElementById('proverb-container');
		const sourceHtml = proverb.source
			? `<cite class="source">, ${proverb.source}</cite>`
			: '';

		container.innerHTML = `
			<article class="proverb">
				<blockquote>
					<p class="quote">${proverb.quote}</p>
				</blockquote>
				<footer class="attribution">
					<span class="author">— ${proverb.author}</span>
					${sourceHtml}
				</footer>
			</article>
		`;
	}

	// Show random proverb on page load
	renderProverb(proverbs[currentIndex]);

	// Handle button click
	document.getElementById('another-btn').addEventListener('click', () => {
		let newIndex;
		do {
			newIndex = Math.floor(Math.random() * proverbs.length);
		} while (newIndex === currentIndex && proverbs.length > 1);
		currentIndex = newIndex;
		renderProverb(proverbs[currentIndex]);
	});
</script>

<style>
	.proverb {
		max-width: 42rem;
		margin: 0 auto;
		padding: 2rem;
		text-align: center;
	}

	blockquote {
		margin: 0;
		padding: 0;
	}

	.quote {
		font-size: clamp(1.5rem, 4vw, 2.25rem);
		line-height: 1.5;
		font-style: italic;
		color: #2c1810;
		margin: 0 0 1.5rem 0;
	}

	.quote::before {
		content: '"';
	}

	.quote::after {
		content: '"';
	}

	.attribution {
		font-size: 1.125rem;
		color: #5c4033;
	}

	.author {
		font-weight: 500;
	}

	.source {
		font-style: italic;
		opacity: 0.85;
	}
</style>
